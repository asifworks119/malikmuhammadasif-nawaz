                    "label": "Vertical Position Of Plus",
                    "min": 0,
                    "max": 100,
                    "step": 1,
                    "unit": "%",
                    "default": 50
                },
                {
                    "type": "range",
                    "id": "plus_left",
                    "label": "Horizontal Position Of Plus",
                    "min": 0,
                    "max": 100,
                    "step": 1,
                    "unit": "%",
                    "default": 50
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Custom Product Grid"
        }
    ]
}
