{% style %}
    .cp-section {
        max-width:1400px;
        margin:0 auto;
        padding: 0 20px;
        margin-top: 6rem;
        margin-bottom:4rem;
    }
    .cp-heading{
        font-size:36px;
        font-family: "Lustria", serif;
        font-weight: 400;
    }
    .cp-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .cp-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        aspect-ratio: 1/1;
    }
    .cp-image-div{
        position:relative;
    }
    .cp-plus-svg{
        position:absolute;
        transform: translate(-50%, -50%);
        cursor: pointer;
    }

    @media (max-width: 768px) {
        .cp-heading{
            font-size:24px;
            text-align:center;
        }
        .cp-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .cp-plus-svg svg{
            width:20px;
        }
    }


    /* POPUP-CSS */
.cp-popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 999;
    align-items: center;
    justify-content: center;
}
.cp-popup-overlay.active {
    display: flex;
}
.cp-popup {
    background: #fff;
    padding: 30px 15px;;
    max-width: 400px;
    position: relative;
    
}
.cp-popup-close {
    position: absolute;
    top: 4px;
    right: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
}
.cp-popup-close svg{
    width:40px;
    height:40px;
}
.cp-popup-div1{
    display: flex;
    gap: 10px;
    align-items: flex-start;
    justify-content: space-between;
}
.cp-popup-img {
    width: 140px;
    height: 160px;
    object-fit: cover;
    flex-shrink: 0;
}
.cp-popup-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.cp-popup-title {
    font-family: "Jost", sans-serif;
    font-size: 20px;
    font-weight: 300;
    margin: 0;
    color:black;
}
.cp-popup-price {
    font-family: "Lustria", serif;
    font-size: 20px;
    font-weight:400;
    margin: 0;
    color:black;
}
.cp-popup-desc {
    font-family: "Jost", sans-serif;
    font-size: 16px;
    font-weight:300;
    margin: 0;
    line-height: 1.2;
    color:black;
}

/* Color-variant-css */
.cp-color-variants-div {
    display: flex;
    flex-wrap: wrap;
    width:100%;
}
.cp-color-variant-btn {
    display: flex;
    align-items: center;
    border: 1px solid #5f5f5f;
    background: #fff;
    cursor: pointer;
    padding: 0;
    font-family: "Jost", sans-serif;
    font-size: 20px;
    font-weight: 300;
    overflow: hidden;
    min-width: 50%;
    color:black;
}
.cp-color-box {
    width: 10px;
    min-height: 100%;
    flex-shrink: 0;
    border-right: 1px solid #5f5f5f;
}
.cp-variant-name {
    font-family: "Jost", sans-serif;
    font-size: 18px;
    font-weight: 300;
    margin: 10px 0 0 0;
    width: 100%;
    color: #333333;
}
.cp-color-label {
    padding: 8px 12px;
    white-space: nowrap;
}
.cp-color-variant-btn.selected {
    background: #000;
    color: #fff;
    border-color: #000;
}
.cp-color-variant-btn.selected .cp-color-box {
    border-right-color: #333;
}

/* Size-variant-css */
.cp-size-dropdown {
    position:relative;
    border: 1px solid #5f5f5f;
    font-family: "Jost", sans-serif;
    font-weight: 300;
}
.cp-size-selected {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 10px 14px;
    background: #fff;
    border: none;
    cursor: pointer;
    font-family: "Jost", sans-serif;
    font-size: 18px;
    font-weight: 300;
    box-sizing: border-box;
    color: #333333;
}
.cp-size-selected svg {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
}
.cp-size-dropdown.open .cp-size-selected svg {
    transform: rotate(180deg);
}
.cp-size-options {
    position: absolute;
    top: 100%;        
    bottom: auto;     
    left: -1px;
    right: -1px;
    max-height: 0;
    overflow-y: auto;
    scrollbar-width: none;
    transition: max-height 0.3s ease;
    background: #fff;
    border: 0px solid #5f5f5f;
    box-sizing: border-box;
    z-index: 10;
}
.cp-size-dropdown.open .cp-size-options {
    max-height: 120px;
    border: 1px solid #5f5f5f;
}
.cp-size-option {
    padding: 10px 14px;
    font-family: "Jost", sans-serif;
    font-size: 18px;
    font-weight: 300;
    cursor: pointer;
    border: none;
    background: #fff;
    text-align: center;
    transition: background 0.2s, color 0.2s;
    width:100%;
    
}
.cp-size-option:hover {
    background: #000;
    color: #fff;
}
.cp-size-label {
    flex: 1;
    text-align: left;
    color:black;
}
.cp-size-label.selected {
    text-align: center;
}


/* Add-to-cart-button-css */
.cp-add-to-cart{
    width:100%;
    margin-top:1rem;
    padding:10px 20px;
    background:#000;
    color:white;
    cursor:pointer;
    font-family: "Jost", sans-serif;
    font-size:18px;
    font-weight:400;
    gap:20px;
    display: flex;
    justify-content: center;
    align-items: center;
}
.cp-cart-error{
    visibility: hidden;
    color:red;
    margin: 0;
}
.cp-cart-error.visible{
    visibility: visible;
    
}
.cp-cart-btn{
margin-top:1rem;
}


@media (max-width: 768px) {
    .cp-popup {
        padding: 30px 20px;
        width: 90%;
    }
    .cp-popup-img {
        width: 120px;
        height: 150px;
    }

    .cp-popup-title {
        font-size: 18px;
    }
    .cp-popup-price {
        font-size: 18px;
    }
    .cp-popup-desc {
        font-size: 13px;
    }
    .cp-variant-name,
    .cp-color-variant-btn,
    .cp-size-selected,
    .cp-add-to-cart{
        font-size: 18px;
    }
    .cp-size-dropdown.open .cp-size-options {
        max-height: 115px;
    }
}


{% endstyle %}

