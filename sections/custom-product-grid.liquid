                <path d="M12.3535 15.2642L18.3367 9.28095" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
                </g>
            </svg>

        </button>

        <div class="cp-popup-div1">
            <img class="cp-popup-img" id="cp-popup-img">
