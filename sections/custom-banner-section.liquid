                },
                {
                    "type": "richtext",
                    "id": "bottom_text_m",
                    "label": "Mobile Text"
                }
            ]
        }
    ],
        
    "presets": [
        {
            "name": "Custom Banner Section",
            "blocks": [
                {"type": "bs1_header"},
                {"type": "bs2_banner"},
                {"type": "bs3_text"}
            ]
        }
    ]
}
{% endschema %}