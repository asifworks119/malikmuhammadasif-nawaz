<div class="main-div">

{% for block in section.blocks %}

    {% if block.type == 'bs1_header' %}
    <div class="bs1-header">
        <div class="bs1-inner">

            {% comment %} Hamburger -mobile {% endcomment %}
            <button class="bs1-hamburger" id="bs1-hamburger" aria-label="Toggle menu">
                <svg class="icon-hamburger" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 6H21M3 12H21M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>

            {% comment %} Logo  {% endcomment %}
            <div class="bs1-logo">
                {% if block.settings.logo != blank %}
                    <img
                        class="bs1-logo_img"
                        src="{{ block.settings.logo | image_url: width:800 }}"
                        width="auto"
                        height="auto"
                    >
                {% else %}
                    <span>{{ shop.name }}</span>
                {% endif %}
            </div>

            {% comment %} Middle text- desktop {% endcomment %}
            {% if block.settings.middle_text != blank %}
                <div class="bs1-middle-text">
                    {{ block.settings.middle_text }}
                </div>
            {% endif %}

            {% comment %} Button - desktop  {% endcomment %}
            {% if block.settings.button_text != blank %}
                <div class="bs1-btn-div">
                    <a class="bs1-btn" href="{{ block.settings.button_link }}">
                        <span class="bs1-btn-text">{{ block.settings.button_text }}</span>
                        <span class="bs1-btn-icon">
                            <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                            </svg>
                        </span>
                    </a>
                </div>
            {% endif %}

        </div>

        {% comment %} Mobile dropdown  {% endcomment %}
        <div class="bs1-mobile-menu" id="bs1-mobile-menu">
            {% if block.settings.middle_text != blank %}
                <div class="bs1-mobile-middle-text">{{ block.settings.middle_text }}</div>
            {% endif %}
            {% if block.settings.button_text != blank %}
                <div class="bs1-mobile-btn-div">
                    <a class="bs1-btn" href="{{ block.settings.button_link }}">
                        <span class="bs1-btn-text">{{ block.settings.button_text }}</span>
                        <span class="bs1-btn-icon">
                            <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                            </svg>
                        </span>
                    </a>
                </div>
            {% endif %}
        </div>

    </div>
    {% endif %}

{% comment %} Hero-Banner-Block {% endcomment %}

    {% if block.type == 'bs2_banner' %}

        <div class="bs2-banner" >
            {% if block.settings.bg_image != blank %}
                <div
                    class="bs2-bg"
                    style="background-image: url({{ block.settings.bg_image | image_url: width:2000 }});"
                >
            {% endif %}

            <div class="bs2-content">
                {%  if block.settings.heading !=blank %} 
                    <h2 class="bs2-content-heading">
                        {{ block.settings.heading }}
                    </h2>
                {% endif %}

                {%  if block.settings.rich_text !=blank %} 
                    <div class="bs2-content-richtext">
                        {{ block.settings.rich_text }}
                    </div>
                {% endif %}

                {%  if block.settings.rich_text_m !=blank %} 
                    <div class="bs2-content-richtext-m">
                        {{ block.settings.rich_text_m }}
                    </div>
                {% endif %}

                {% if block.settings.button_text != blank %}
                    <div class="bs2-btn-div">
                        <a class="bs2-btn" href="{{ block.settings.button_link }}">
                            <span class="bs2-btn-text">{{ block.settings.button_text }}</span>
                            <span class="bs2-btn-icon">
                                <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                                </svg>
                            </span>
                        </a>
                    </div>
                {% endif %}

            </div>

            <div class="bs2-mobile-img-div">
                {% if block.settings.mobile_image !=blank%}
                    <img
                        class="bs2-mobile-img"
                        src="{{ block.settings.mobile_image |  image_url: width:800  }}"
                    
                    >
                                   
                {% endif %}
                {% if block.settings.button_text != blank %}
                    <div class="bs2-btn-div-m">
                        <a class="bs2-btn" href="{{ block.settings.button_link }}">
                            <span class="bs2-btn-text">{{ block.settings.button_text }}</span>
                                <span class="bs2-btn-icon">
                                    <svg width="26" height="12" viewBox="0 0 26 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
                                    </svg>
                                </span>
                        </a>
                    </div>
                {% endif %}
            </div>


        </div>
    {% endif %}

{% comment %} Bottom-text-line {% endcomment %}
    
    {% if block.type == 'bs3_text' %}
        <div class="bs3-text-desktop">
            {{ block.settings.bottom_text }}
        </div>
        <div class="bs3-text-mobile">
            {{ block.settings.bottom_text_m }}
        </div>
    {% endif %}

{% endfor %}
</div>


{% style %}

/* Block3-Bottom-Text-CSS */
.bs3-text-desktop,
.bs3-text-mobile {
    text-align: center;
    font-family: "Jost", sans-serif;
    font-size: 16px;
    font-weight: 400;
    padding: 10px 20px;
    background: #f7f7f7;
    text-transform: uppercase;
    color:black;
}
.bs3-text-desktop p,
.bs3-text-mobile p{
     margin:0;
}

.bs3-text-mobile {
    display: none;
}

@media (max-width: 768px) {
    .bs3-text-desktop {
        display: none;
    }
    .bs3-text-mobile {
        display: block;
        font-size: 14px;
    }
}


/* Block2-Hero-banneer-css */
.bs2-bg{
    width:100%;
    position:relative;
    background-size:cover;
    background-position:center center;
    background-repeat: no-repeat;
    height:780px;
    max-width:1600px;
    margin: 0 auto;
}
.bs2-content-heading{
    font-family: "Jost", sans-serif;
    font-weight:500;
    font-size:70px;
    margin-bottom:1rem;
}
.bs2-content-richtext{
    font-family: "Jost", sans-serif;
    font-weight:400;
    font-size:20px;
    max-width:500px;
    line-height:1.6;
    color: black;
    margin-bottom:2rem;
}

.bs2-content{
    max-width:1400px;
    margin:0 auto;
    display:flex;
    flex-direction:column;
    height:100%;
    justify-content: end;
    padding-left:35px;
}
.bs2-btn-div{
    margin-bottom:4rem;
}
.bs2-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 20px;
    font-family: "Jost", sans-serif;
    font-size: 16px;
    font-weight:400;
    text-decoration: none;
    text-transform: uppercase;
    padding: 10px 40px;
    color: white;
    background: black;
    overflow: hidden;
    z-index: 1;
}

.bs2-btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0%;
    height: 100%;
    background: #fff544;
    transition: width 0.3s ease;
    z-index: -1;
}

.bs2-btn:hover::before {
    width: 100%;
}

.bs2-btn:hover {
    color: black;
}

.bs2-mobile-img-div,
.bs2-content-richtext-m,
.bs2-btn-div-m{
    display:none;
}

@media (min-width: 989px) and (max-width: 1280px) { 
    .bs2-bg{
        height:620px;
    }
    .bs2-content-heading{
        font-size:50px;
        margin-bottom:0;
    }
    .bs2-content-richtext{
        max-width:420px;
        margin-bottom:0;
    }
    .bs2-btn-div{
        margin-bottom:1rem;
    }
}

@media (max-width: 989px){
    .bs2-mobile-img-div{
        position:relative;
        display:block;
    }
    .bs2-content-richtext-m,
    .bs2-btn-div-m{
        display:block;
    }
    .bs2-bg{
        background-image:none !important;
        height:auto;
    }
    .bs2-mobile-img{
        width:100%;
    }

    .bs2-btn-div,
    .bs2-content-richtext{
        display:none;
    }
    .bs2-content{
        height:auto;
        text-align: center;
        padding-left: 0;
    }
    .bs2-content-heading{
        font-size:30px;
        margin-top:7rem;
        margin-bottom:0;
    }
    .bs2-content-richtext-m{
        font-size:16px;
        max-width:85%;
        margin:0 auto;
        font-weight:400;
        color:black;
        font-family: "Jost", sans-serif;
    }
    .bs2-btn-div-m{
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: max-content;
    }
    .bs2-btn{
        font-size:16px;
        padding: 8px 34px;
        gap:20px;
    }
}


/* Block1-Header-css */
.bs1-header {
    position: relative;
    width: 100%;
    background: #f7f7f7;
    border-bottom: 1px solid #00000040;
}

.bs1-inner {
    max-width: 1400px;
    margin: 0 auto;
    height: 64px;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.bs1-logo{
    line-height:0;
}
.bs1-logo_img {
    width: auto;
    height: 19px;
}

.bs1-middle-text {
    font-family: "Jost", sans-serif;
    font-size: 16px;
    font-weight: 400;
}

.bs1-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 20px;
    font-family: "Jost", sans-serif;
    font-size: 16px;
    text-decoration: none;
    text-transform: uppercase;
    padding: 5px 20px;
    color: black;
    background: #fff544;
    overflow: hidden;
    z-index: 1;
}

.bs1-btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0%;
    height: 100%;
    background: black;
    transition: width 0.3s ease;
    z-index: -1;
}

.bs1-btn:hover::before {
    width: 100%;
}

.bs1-btn:hover {
    color: white;
}


.bs1-hamburger {
    display: none;
}


.bs1-mobile-menu {
    display: none;
}

.bs1-mobile-menu {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 0 20px;
    background: #f7f7f7;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
}


/*  MOBILE css  */
@media (max-width: 989px) {

    
    .bs1-middle-text,
    .bs1-btn-div {
        display: none;
    }

    
    .bs1-inner {
        justify-content: center;
        position: relative;
        box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px 0px;
    }

    
    .bs1-hamburger {
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        left: 20px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        color: black;
    }

    
    .bs1-hamburger .icon-close {
        display: none;
    }

    .bs1-hamburger .icon-hamburger {
        display: block;
    }


    .bs1-mobile-menu.open {
        max-height: 300px;
        padding: 20px;
    }

    .bs1-mobile-middle-text {
        font-family: "Jost", sans-serif;
        font-size: 16px;
        font-weight: 400;
        color:black;
    }
    .bs1-btn{
        gap:20px;
        padding:8px 34px;
    }
}

{% endstyle %}


{% javascript %}

    document.addEventListener('DOMContentLoaded', function () {
        const hamburger = document.getElementById('bs1-hamburger');
        const menu = document.getElementById('bs1-mobile-menu');
        const iconOpen = hamburger.querySelector('.icon-hamburger');
        const iconClose = hamburger.querySelector('.icon-close');

        hamburger.addEventListener('click', function () {
            const isOpen = menu.classList.toggle('open');
            iconOpen.style.display = isOpen ? 'none' : 'block';
            iconClose.style.display = isOpen ? 'block' : 'none';
        });
    });
{% endjavascript %}


{% schema %}
{
    "name": "Custom Banner Section",
    "tag": "section",
    "class": "bs-section",
    "max_blocks": 3,
    "settings": [],
    "blocks": [
        {
            "type": "bs1_header",
            "name": "Header",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "logo",
                    "label": "Logo Image"
                },
                {
                    "type": "text",
                    "id": "middle_text",
                    "label": "Middle Banner Text"
                },
                {
                    "type": "text",
                    "id": "button_text",
                    "label": "Button Label"
                },
                {
                    "type": "url",
                    "id": "button_link",
                    "label": "Button Link"
                }
            ]
        },
        {
            "type": "bs2_banner",
            "name": "Hero Banner",
            "settings":[
                {
                    "type": "image_picker",
                    "id": "bg_image",
                    "label": "Desktop Image"
                },
                {
                    "type": "image_picker",
                    "id": "mobile_image",
                    "label": "Mobile Image"
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading"
                },
                {
                    "type": "richtext",
                    "id": "rich_text",
                    "label": "Paragrah"
                },
                {
                    "type": "richtext",
                    "id": "rich_text_m",
                    "label": "Paragrah for Mobile"
                },
                {
                    "type": "text",
                    "id": "button_text",
                    "label": "Button Text"
                },
                {
                    "type": "url",
                    "id":"button_link",
                    "label": "Button Link"
                }
            ]
        },
        {
            "type": "bs3_text",
            "name": "Bottom Text",
            "settings": [
                {
                    "type": "richtext",
                    "id": "bottom_text",
